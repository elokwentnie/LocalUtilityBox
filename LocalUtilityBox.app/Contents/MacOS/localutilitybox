#!/bin/bash
# Launch LocalUtilityBox GUI as a macOS app.
# When launched from Finder, env is minimal — use Homebrew Python explicitly so Tkinter works.

# Prefer Homebrew Python (has python-tk@3.14); fallback to whatever python3 is in PATH
PYTHON=""
for p in /opt/homebrew/opt/python@3.14/bin/python3.14 /opt/homebrew/bin/python3 /usr/local/bin/python3; do
    if [[ -x "$p" ]] && "$p" -c "import tkinter" 2>/dev/null; then
        PYTHON="$p"
        break
    fi
done
if [[ -z "$PYTHON" ]]; then
    if command -v python3 &>/dev/null; then
        PYTHON="python3"
    else
        echo "No Python with Tkinter found. Install with:"
        echo "  brew install python-tk@3.14"
        echo ""
        read -n 1 -p "Press any key to close..."
        exit 1
    fi
fi

export PATH="$HOME/Library/Python/3.14/bin:$HOME/.local/bin:/opt/homebrew/bin:$PATH"

# Prefer installed CLI so it uses same Python and site-packages
if command -v localutilitybox-gui &>/dev/null; then
    if ! "$PYTHON" -c "import tkinter" 2>/dev/null; then
        echo "Tkinter is missing for this Python. Install: brew install python-tk@3.14"
        read -n 1 -p "Press any key to close..."
        exit 1
    fi
    exec "$PYTHON" -m gui.main_gui
fi

# Fallback: run from project (when .app is inside the usefulday repo)
APP_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
PROJECT_ROOT="$(cd "$APP_ROOT/.." && pwd)"
SRC="$PROJECT_ROOT/src"
if [[ -d "$SRC/gui" ]]; then
    export PYTHONPATH="$SRC:$PYTHONPATH"
    exec "$PYTHON" -m gui.main_gui
fi

echo "LocalUtilityBox not found. Install with: pip3 install --user --break-system-packages ."
read -n 1 -p "Press any key to close..."
exit 1
